# GEMINI_API_KEY: Required for the cloud composition AI model calls.
# This is automatically injected at runtime from user secrets.
# Users configure this via the Secrets configuration panel.
GEMINI_API_KEY="YOUR_API_KEY"

# APP_URL: The URL where this applet is hosted.
# This is automatically injected at runtime with the hosted service URL.
# Used for self-referential links, callbacks, and API endpoints.
APP_URL="YOUR_APP_URL"
